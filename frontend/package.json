{
  "name": "campusops-frontend",
  "version": "1.0.0",
  "description": "CampusOps Fulfillment & Operations Platform — Vue 3 Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:component": "vitest run unit_tests/**/*.component.test.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.8",
    "dayjs": "^1.11.10",
    "element-plus": "^2.7.0",
    "pinia": "^2.1.7",
    "socket.io-client": "^4.7.5",
    "uuid": "^9.0.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^20.12.2",
    "@types/uuid": "^9.0.8",
    "@vue/test-utils": "^2.4.6",
    "@vitejs/plugin-vue": "^5.0.4",
    "jsdom": "^24.1.1",
    "typescript": "^5.4.3",
    "vite": "^5.2.7",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.11"
  }
}
